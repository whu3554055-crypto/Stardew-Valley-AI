# Hello-Agent Backend Configuration
# Copy this file to .env and modify as needed

# ============================================================================
# Application Settings
# ============================================================================
DEBUG=false
HOST=0.0.0.0
PORT=8080

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ============================================================================
# Database Configuration
# ============================================================================
SQLITE_DB_PATH=data/stardew_game.db
LANCEDB_PATH=data/vector_store
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# Default provider for general tasks (ollama, qwen, gemini, openai)
DEFAULT_LLM_PROVIDER=ollama

# ----------------------------------------------------------------------------
# Ollama Configuration (Local - Recommended for development)
# ----------------------------------------------------------------------------
# Install: https://ollama.com/download
# Models: ollama pull qwen3.5:9b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# ----------------------------------------------------------------------------
# Qwen Configuration (Alibaba Cloud DashScope)
# ----------------------------------------------------------------------------
# Get API Key: https://dashscope.console.aliyun.com/
# Pricing: ~$0.002/1K tokens (qwen-plus)
QWEN_API_KEY=your-dashscope-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v2

# ----------------------------------------------------------------------------
# Gemini Configuration (Google AI)
# ----------------------------------------------------------------------------
# Get API Key: https://makersuite.google.com/app/apikey
# Free tier: 60 RPM, $0.0005/1K tokens after
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro
GEMINI_EMBEDDING_MODEL=models/embedding-001

# ----------------------------------------------------------------------------
# OpenAI Configuration (Optional)
# ----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4-turbo
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Smart Routing Configuration
# ============================================================================
# Enable smart routing based on task type
SMART_ROUTING_ENABLED=true

# Provider priority order (fallback chain)
PROVIDER_PRIORITY=ollama,qwen,gemini

# Task-specific routing (override default behavior)
ROUTING_NPC_DIALOGUE=ollama
ROUTING_STORY_GENERATION=qwen
ROUTING_EMOTION_ANALYSIS=ollama
ROUTING_COMPLEX_REASONING=qwen
ROUTING_CREATIVE_WRITING=gemini

# Cost control
MAX_DAILY_BUDGET_USD=5.0
CLOUD_FALLBACK_ON_ERROR=true

# ============================================================================
# Embedding Model (Legacy - now handled by providers)
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============================================================================
# Agent Configuration
# ============================================================================
MAX_CONCURRENT_AGENTS=10
AGENT_TIMEOUT_SECONDS=30
MEMORY_RETRIEVAL_K=5

# ============================================================================
# Performance & Logging
# ============================================================================
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=2

LOG_LEVEL=INFO
LOG_FILE=logs/backend.log
