# Godot 4+ specific ignores
.godot/
*.import
*.translation

# Python backend
hello_agent_backend/__pycache__/
hello_agent_backend/*.pyc
hello_agent_backend/*.pyo
hello_agent_backend/.pytest_cache/
hello_agent_backend/venv/
hello_agent_backend/.env
hello_agent_backend/data/vector_store/
hello_agent_backend/data/*.db
hello_agent_backend/data/*.sqlite
hello_agent_backend/tests/__pycache__/
hello_agent_backend/app/**/__pycache__/
hello_agent_backend/llm/**/__pycache__/

# Redis dump
dump.rdb

# Environment variables and secrets
.env
.env.local
.env.*.local
*.secret
credentials.json
service-account.json
# Local LLM keys for DashScope / Aliyun (copy from ai_secrets.json.example)
data/local/ai_secrets.json

# IDE and Editor files (keep shared configs)
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/**/*
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build outputs
build/
dist/
*.export
*.pck
*.zip
*.exe
*.dmg
*.apk
*.aab

# Logs
*.log
logs/
tools/last_smoke_log.txt
tools/last_gut_log.txt
_gut_extract/
_gut.zip
_gut_vendor/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Windows artifact (reserved name; accidental empty files)
nul

# Documentation build
docs/_build/
docs/build/
site/

# Test coverage
coverage/
.coverage
htmlcov/
*.cover

# Node modules (if using npm/yarn for tooling)
node_modules/
package-lock.json
yarn.lock

# Database files (development)
*.db-journal
*.db-wal

# Vector database cache
lancedb_data/
vector_store/

# Backup files
*.backup
.bak
data/quests/backups/

# Generated configs
config_override.cfg
